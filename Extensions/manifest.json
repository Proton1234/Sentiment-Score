{
  "manifest_version": 3,
  "name": "Sentiment Score",
  "version": "1.1",
  "description": "Analyze the sentiment of the current page using GPT and display a labeled, scored, and explained result.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ]
}
